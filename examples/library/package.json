{
  "name": "library-ts",
  "version": "0.0.0",
  "description": "Marko library project with TypeScript",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "marko.json",
    "!**/*.test.*",
    "!*.tsbuildinfo",
    "!**/{,*.}stories.*"
  ],
  "scripts": {
    "@ci:build": "npm run build",
    "@ci:lint": "npm run lint",
    "@ci:test": "CI=true vitest --no-color",
    "build": "mtc && postcss 'src/**/*.css' --base src -d dist",
    "clean": "rm -rf coverage dist node_modules/.{cache,vite*}",
    "format": "eslint --format unix --fix .; prettier . --write --log-level=warn",
    "lint": "mtc && eslint --format unix . && prettier . --check --log-level=warn",
    "prepare": "husky",
    "storybook": "storybook dev",
    "test": "vitest"
  },
  "devDependencies": {
    "@eslint/css": "^0.14.1",
    "@eslint/js": "^9.39.2",
    "@marko/compiler": "^5.39.48",
    "@marko/testing-library": "^6.4.1",
    "@marko/type-check": "^2.1.18",
    "@marko/vite": "^5.4.2",
    "@storybook/marko": "^10.0.1",
    "@storybook/marko-vite": "^4.1.0",
    "@types/node": "^25.0.10",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/browser-preview": "^4.0.18",
    "@vitest/coverage-istanbul": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-formatter-unix": "^9.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "marko": "^6.0.103",
    "playwright": "^1.58.0",
    "postcss-auto-modules": "^1.0.1",
    "postcss-cli": "^11.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-marko": "^3.3.2",
    "prettier-plugin-packagejson": "^3.0.0",
    "storybook": "^10.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "marko": "5 - 6"
  }
}
